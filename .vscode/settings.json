{
  // Use conda environment 'hrv-py312' instead of .venv
  "python.defaultInterpreterPath": "${env:USERPROFILE}\\anaconda3\\envs\\hrv-py312\\python.exe",
  
  // Point to Anaconda conda.exe
  "python.condaPath": "${env:USERPROFILE}\\anaconda3\\Scripts\\conda.exe",
  
  // Enable conda environment in terminal
  "python.terminal.activateEnvironment": true,
  "python.terminal.activateEnvInCurrentTerminal": true,
  
  // Prefer conda environments over venv
  "python.venvPath": "",
  "python.pythonPath": "${env:USERPROFILE}\\anaconda3\\envs\\hrv-py312\\python.exe",
  
  // Use local Jupyter server
  "jupyter.jupyterServerType": "local",
  "jupyter.logging.level": "error",
  
  // Terminal settings - ensure conda activation works
  "terminal.integrated.env.windows": {
    "CONDA_DEFAULT_ENV": "hrv-py312"
  }
}

