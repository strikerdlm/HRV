{
  // Ensure Cursor/VS Code uses the project .venv interpreter
  // Uses workspace-relative path that works across different user directories
  "python.defaultInterpreterPath": "${workspaceFolder}\\.venv\\Scripts\\python.exe",
  // Point Python tooling at the Miniconda conda.exe to avoid Anaconda conflicts
  // Note: Update this path to match your Miniconda installation location
  "python.condaPath": "${env:USERPROFILE}\\Miniconda3\\Scripts\\conda.exe",
  // Make terminals auto-activate the selected interpreter
  "python.terminal.activateEnvironment": true,
  // Use local Jupyter server (remove remote config if not using remote server)
  "jupyter.jupyterServerType": "local",
  "jupyter.logging.level": "error"
}

