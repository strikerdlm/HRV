# Author: Dr Diego Malpica MD
# Environment variables for the TypeScript frontend

# API URL - FastAPI backend (default: http://localhost:8180)
# Change this if you need a different port or remote server
NEXT_PUBLIC_API_URL=http://localhost:8180

# Server-side API URL (for SSR, if different from public URL)
API_URL=http://localhost:8180

# For production deployment:
# NEXT_PUBLIC_API_URL=https://your-api-server.com
# API_URL=https://your-api-server.com

# -----------------------------------------------------------------
# Port Configuration Summary:
# -----------------------------------------------------------------
# Frontend (Next.js): http://localhost:3100 (configured in package.json)
# Backend (FastAPI):  http://localhost:8180 (configured in api/main.py)
#
# To use custom ports, update:
#   1. frontend/package.json (dev/start scripts)
#   2. api/main.py (uvicorn port + CORS origins)
#   3. This .env file (NEXT_PUBLIC_API_URL)
# -----------------------------------------------------------------
